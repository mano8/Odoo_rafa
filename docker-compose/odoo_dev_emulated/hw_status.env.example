# hw_status env for the emulated debug stack — rename to hw_status.env
DOMAIN="localhost"
ENVIRONMENT="development"

API_PREFIX="/hw_status"
SET_OPEN_API=true
SET_DOCS=true
SET_REDOC=true

PROJECT_NAME="OdooHwStatus"
STACK_NAME="emulated-debug-hw-status"

# Paths inside the container (volume-mounted from ../../hw_status/hw_status)
STATIC_BASE_PATH="/opt/hw_status/app/static"
TEMPLATES_BASE_PATH="/opt/hw_status/app/templates"

# Odoo is on port 9000
BACKEND_HOST="http://localhost:9000"

# hw_proxy address — injected into the status dashboard JS at render time
HW_PROXY_URL="http://localhost:9002"

# Change this to a strong random value
SECRET_KEY="changethis"

PRINTER_KEY="EMULATED"
LOG_LEVEL="Debug"

# Set to "true" to enable debugpy (attach from VS Code on port 5678)
VSCODE_DEBUG=false
