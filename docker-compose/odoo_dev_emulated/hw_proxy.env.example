# hw_proxy env for the emulated debug stack — rename to hw_proxy.env
DOMAIN="localhost"
ENVIRONMENT="development"

API_PREFIX="/hw_proxy"
SET_OPEN_API=true
SET_DOCS=true
SET_REDOC=true

PROJECT_NAME="OdooHwProxy"
STACK_NAME="emulated-debug-hw-proxy"

# Paths inside the container (volume-mounted from ../../hw_proxy/hw_proxy)
STATIC_BASE_PATH="/opt/hw_proxy/app/static"
TEMPLATES_BASE_PATH="/opt/hw_proxy/app/templates"

# Odoo is on port 9000, hw_proxy itself on 9002
BACKEND_HOST="http://localhost:9000"
FRONTEND_HOST="http://localhost:9002"
BACKEND_CORS_ORIGINS="http://localhost:9000,http://localhost:9002,http://localhost:8015"

# Change this to a strong random value
SECRET_KEY="changethis"

# Talk to the emulator instead of a real printer.
PRINTER_KEY="EMULATED"
# NOTE: EMULATED_PRINTER_HOST / EMULATED_PRINTER_PORT are NOT set here.
# hw_proxy Settings use extra="forbid" and load the whole .env file, so any
# non-field key here is rejected. They are read via os.environ in
# supported_devices.py, so they are passed through the compose `environment:`
# block (real process env) instead — see docker-compose.yml.

LOG_LEVEL="Debug"

# Set to "true" to enable debugpy (attach from VS Code on port 5679)
VSCODE_DEBUG=false
