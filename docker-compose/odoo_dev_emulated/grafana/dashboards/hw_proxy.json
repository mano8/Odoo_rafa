{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 10,
      "title": "Hardware Status",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "red", "index": 0, "text": "OFFLINE" }, "1": { "color": "green", "index": 1, "text": "ONLINE" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Printer Online",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "hw_proxy_printer_online", "legendFormat": "online", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "orange", "index": 0, "text": "LOW / UNKNOWN" }, "1": { "color": "green", "index": 1, "text": "OK" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }, { "color": "green", "value": 1 }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Paper Status",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "hw_proxy_printer_paper_ok", "legendFormat": "paper", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops" }
      },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Cash Drawer Operations / s",
      "type": "timeseries",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(hw_proxy_cashdrawer_operations_total[1m])", "legendFormat": "{{result}}", "refId": "A" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 11,
      "title": "Print Jobs",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Print Jobs / s",
      "type": "timeseries",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(hw_proxy_print_jobs_total[1m])", "legendFormat": "{{action}} / {{result}}", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "API Response Time (encode + queue) — p50/p90/p99",
      "description": "Time from request received to response sent. Fire-and-forget: serial write runs in background.",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, rate(hw_proxy_print_duration_seconds_bucket[5m]))", "legendFormat": "p50 {{action}}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.90, rate(hw_proxy_print_duration_seconds_bucket[5m]))", "legendFormat": "p90 {{action}}", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, rate(hw_proxy_print_duration_seconds_bucket[5m]))", "legendFormat": "p99 {{action}}", "refId": "C" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "hardware floor (115200 baud)" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 13,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Serial Write Duration (hardware floor = bytes × 10 / 115200)",
      "description": "Actual time spent blocking on serial port write. At 115200 baud: 55 KB ≈ 4.8 s. Reduce payload or increase baud rate to improve.",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, rate(hw_proxy_serial_write_duration_seconds_bucket[5m]))", "legendFormat": "p50", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.90, rate(hw_proxy_serial_write_duration_seconds_bucket[5m]))", "legendFormat": "p90", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, rate(hw_proxy_serial_write_duration_seconds_bucket[5m]))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 12,
      "title": "HTTP Layer",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Request Rate by Endpoint",
      "type": "timeseries",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(hw_proxy_http_requests_total[1m])", "legendFormat": "{{method}} {{endpoint}} {{status_code}}", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 7,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "HTTP Latency p95 by Endpoint",
      "type": "timeseries",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, rate(hw_proxy_http_request_duration_seconds_bucket[5m]))", "legendFormat": "p95 {{endpoint}}", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 8,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "5xx Error Rate",
      "type": "timeseries",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(hw_proxy_http_requests_total{status_code=~\"5..\"}[1m])", "legendFormat": "{{endpoint}}", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 9,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Print Error Rate",
      "type": "timeseries",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(hw_proxy_print_jobs_total{result=\"error\"}[1m])", "legendFormat": "{{action}}", "refId": "A" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 30,
      "title": "Print Pipeline (queue / overflow)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 32 },
      "id": 31,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Print Queue Depth (jobs_queued)",
      "description": "Jobs waiting in the hw_proxy drain queue. Stays low when pacing keeps up; a growing queue means the printer is the bottleneck.",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "hw_proxy_print_queue_depth", "legendFormat": "hw_proxy queue", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "emulated_printer_jobs_queued", "legendFormat": "emulator jobs_queued", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 32 },
      "id": 32,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Jobs Printed (session)",
      "description": "Receipts the drain worker has written over the selected time range.",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "increase(hw_proxy_print_jobs_total{result=\"printed\"}[$__range])", "legendFormat": "printed", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 32 },
      "id": 33,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Printer Buffer Size",
      "description": "Configured input-buffer size. hw_proxy reports the device profile value; the emulator reports its live ground-truth value.",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "hw_proxy_printer_buffer_size_bytes", "legendFormat": "hw_proxy", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "emulated_printer_buffer_size_bytes", "legendFormat": "emulator", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 32 },
      "id": 34,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Overflow / Lost (session)",
      "description": "hw_proxy: jobs it lost (cleared/reset or write error) — 0 = healthy. emulator: true firmware overflow events. Range = printing session.",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "increase(hw_proxy_print_overflow_events_total[$__range])", "legendFormat": "hw_proxy lost {{cause}}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "increase(emulated_printer_overflow_events[$__range])", "legendFormat": "emulator overflow_events", "refId": "B" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "id": 40,
      "title": "Emulator (ground truth)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "id": 41,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Buffer Occupancy vs Size",
      "description": "Bytes pending in the emulator buffer against its capacity. Pacing keeps occupancy well below buffer_size; an unpaced burst pushes it to the ceiling and overflows.",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "emulated_printer_pending_bytes", "legendFormat": "pending", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "emulated_printer_buffer_size_bytes", "legendFormat": "buffer_size", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "id": 42,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Overflow Events & Bytes (cumulative)",
      "description": "Emulator ground-truth overflow counters. Flat = no drops; any rise reproduces the receipt-drop cliff.",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "emulated_printer_overflow_events", "legendFormat": "overflow_events", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "emulated_printer_overflow_bytes", "legendFormat": "overflow_bytes", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 49 },
      "id": 43,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Jobs Printed / Queued",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "emulated_printer_jobs_printed", "legendFormat": "jobs_printed", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "emulated_printer_jobs_queued", "legendFormat": "jobs_queued", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 49 },
      "id": 44,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Bytes Received / Printed (cumulative)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "emulated_printer_bytes_received", "legendFormat": "received", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "emulated_printer_bytes_printed", "legendFormat": "printed", "refId": "B" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 57 },
      "id": 50,
      "title": "Printer Tuning (active config)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "mappings": [{ "options": { "1": { "text": "ACTIVE", "color": "green" } }, "type": "value" }],
          "displayName": "${__field.labels.strategy}",
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 58 },
      "id": 51,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Active Strategy",
      "description": "Flow-control strategy currently selected in the Printer Tuning card.",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "hw_proxy_print_strategy_active == 1", "legendFormat": "{{strategy}}", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "text" }, "displayName": "${__field.labels.setting}", "unit": "short" } },
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 58 },
      "id": 52,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Tuning Parameters (pace / chunk / status_poll)",
      "description": "Live values from PrintSettings. *_ms in milliseconds; chunk_size in bytes. Only the active strategy's parameters take effect.",
      "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "hw_proxy_print_setting", "legendFormat": "{{setting}}", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 30, "lineWidth": 2, "spanNulls": true, "showPoints": "never" }, "min": 0, "max": 1, "unit": "short" } },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 64 },
      "id": 53,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Active Strategy Over Time",
      "description": "Step plot of which flow-control strategy was live (1) vs inactive (0). Use it to line strategy switches up with overflow / throughput during an A/B sweep.",
      "type": "timeseries",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "hw_proxy_print_strategy_active", "legendFormat": "{{strategy}}", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 10, "lineWidth": 2, "spanNulls": true, "showPoints": "never" }, "unit": "short" } },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 64 },
      "id": 54,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Tuning Parameters Over Time",
      "description": "Step plot of each PrintSettings parameter (*_ms in ms, chunk_size in bytes) so changes made from the Printer Tuning card are visible over time.",
      "type": "timeseries",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "hw_proxy_print_setting", "legendFormat": "{{setting}}", "refId": "A" }]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["hw_proxy", "pos", "printer"],
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "hw_proxy — Printer & POS",
  "uid": "hw-proxy-pos",
  "version": 4
}
