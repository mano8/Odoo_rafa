# Dockerfile.offline.dev
FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1 \
    PATH="/home/appuser/.local/bin:$PATH"

RUN apt-get update && apt-get install -y --no-install-recommends \
      gcc \
      build-essential \
      python3-dev \
      pkg-config \
      dos2unix \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd --gid 1000 appuser && \
    useradd --uid 1000 --gid appuser --create-home appuser

# Set working directory
WORKDIR /opt

# Create the app directories and set permissions
RUN mkdir -p hw_status
# Copy the hw_status source code
COPY --chown=appuser:appuser ./hw_status ./hw_status
RUN chown -R appuser:appuser ./hw_status

# Copy requirements and install them as the non-root user
COPY --chown=appuser:appuser ./hw_status/requirements-docker-dev.txt .
COPY --chown=appuser:appuser ./wheelhouse_dev ./wheelhouse

# Switch to the non-root user
USER appuser

# Install Python dependencies from local wheelhouse
# Use --no-cache-dir to avoid caching the packages in the image
# Use --user to install packages in the user's home directory
RUN pip install --no-index --no-cache-dir --user \
      --find-links=wheelhouse \
      -r requirements-docker-dev.txt


# /opt is on sys.path so `import hw_status` resolves to /opt/hw_status/
ENV PYTHONPATH=/opt

EXPOSE 8015
EXPOSE 5678

# Inline startup so CRLF line endings in volume-mounted scripts never cause issues.
# exec replaces the shell (PID 1) with the target process for correct signal handling.
CMD ["bash", "-c", "if [ \"$VSCODE_DEBUG\" = \"true\" ]; then exec python -m debugpy --listen 0.0.0.0:5678 --wait-for-client -m uvicorn hw_status.main:app --host 0.0.0.0 --port 8015 --reload; else exec uvicorn hw_status.main:app --host 0.0.0.0 --port 8015 --reload --proxy-headers --forwarded-allow-ips \"*\"; fi"]