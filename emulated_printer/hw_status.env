# hw_status env for the emulator stack
DOMAIN="localhost"
ENVIRONMENT="development"

API_PREFIX="/hw_status"
SET_OPEN_API=true
SET_DOCS=true
SET_REDOC=true

PROJECT_NAME="OdooHwStatus"
STACK_NAME="emulated-printer-hw-status"

# Paths inside the container (volume-mounted from ../hw_status/hw_status)
STATIC_BASE_PATH="/opt/hw_status/app/static"
TEMPLATES_BASE_PATH="/opt/hw_status/app/templates"

# No Odoo in this stack
BACKEND_HOST="http://localhost:9000"

SECRET_KEY="Local-Dev_Key123Xyz789AbcSecure-0001"

PRINTER_KEY="EMULATED"
LOG_LEVEL="Debug"

# HW_PROXY_URL: URL hw_status uses to reach hw_proxy (browser → host port 9002).
HW_PROXY_URL="http://localhost:9002"

# Set to "true" to enable debugpy (attach from VS Code on port 5678)
VSCODE_DEBUG=false
