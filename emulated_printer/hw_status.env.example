# hw_status env for the emulator stack — rename to hw_status.env
DOMAIN="localhost"
ENVIRONMENT="development"

API_PREFIX="/hw_status"
SET_OPEN_API=true
SET_DOCS=true
SET_REDOC=true

PROJECT_NAME="OdooHwStatus"
STACK_NAME="emulated-printer-hw-status"

STATIC_BASE_PATH="/opt/hw_status/app/static"
TEMPLATES_BASE_PATH="/opt/hw_status/app/templates"

BACKEND_HOST="http://localhost:9000"

# hw_proxy address injected into the dashboard JS (browser → host port 9002).
HW_PROXY_URL="http://localhost:9002"

SECRET_KEY="changethis"

PRINTER_KEY="EMULATED"
LOG_LEVEL="Debug"
VSCODE_DEBUG=false
